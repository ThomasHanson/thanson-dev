<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject }}</title>
  <!-- Include the output.css file generated by Tailwind CSS -->
  <link rel="stylesheet" href="path/to/output.css">
</head>
<body>
  <div class="max-w-2xl mx-auto p-4">
    {{#if showGreeting}}
      <h3 class="text-2xl font-bold mb-4">Hi {{ firstName }},</h3>
    {{/if}}

    <p class="text-lg mb-4">{{ bodyText }}</p>

    <div class="mb-4">
      <p class="font-bold">Name:</p>
      <p class="text-lg">{{ firstName }} {{ lastName }}</p>
    </div>

    <div class="mb-4">
      <p class="font-bold">Phone Number:</p>
      <p class="text-lg">{{ phoneNumber }}</p>
    </div>

    <div class="mb-4">
      <p class="font-bold">Email:</p>
      <p class="text-lg">{{ emailAddress }}</p>
    </div>

    <div class="mb-4">
      <p class="font-bold">Preferred Contact Method:</p>
      <p class="text-lg">{{ preferredCommMethod }}</p>
    </div>

    <div class="mb-4">
      <p class="font-bold">Comments:</p>
      <p class="text-lg">{{ comments }}</p>
    </div>

    {{#if includeRegards}}
      <p class="text-sm">Regards,</p>
      <p class="text-sm">{{ senderName }}</p>
    {{/if}}
  </div>
</body>
</html>
